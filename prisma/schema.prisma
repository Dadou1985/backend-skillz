// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URL moved to prisma.config.ts
}

model Hotel {
  id           String   @id @default(cuid())
  hotelName    String
  adresse      String
  city         String
  classement   String
  code_postal  String
  country      String
  departement  String
  region       String
  lat          Float
  lng          Float
  mail         String
  partnership  Boolean
  phone        String
  room         Int
  website      String
  appLink      String?
  base64Url    String?
  logo         String?
  pricingModel String?

  createdAt    DateTime
  updatedAt    DateTime

  chatRoom      Chat[] 
  businessUsers BusinessUser[]
  guestUsers    GuestUser[]
  feedbacks     Feedback[]
  supports      Support[]
  checkLists    CheckList[]
  roomAmeneties  RoomAmeneties[]

  @@map("hotels")
}
model CheckList {
  id           String   @id @default(cuid())
  hotelId      String
  morning      CheckListItem[] @relation("MorningItems")
  evening      CheckListItem[] @relation("EveningItems")
  night        CheckListItem[] @relation("NightItems")

  createdAt    DateTime
  updatedAt    DateTime

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@map("check_lists")
}
model CheckListItem {
  id           String   @id @default(cuid())
  task         String
  status       Boolean
  checkListId  String
  morningId    String?
  eveningId    String?
  nightId      String?

  createdAt    DateTime
  updatedAt    DateTime

  morning CheckList? @relation("MorningItems", fields: [morningId], references: [id], onDelete: Cascade)
  evening CheckList? @relation("EveningItems", fields: [eveningId], references: [id], onDelete: Cascade)
  night   CheckList? @relation("NightItems", fields: [nightId], references: [id], onDelete: Cascade)

  @@index([morningId])
  @@index([eveningId])
  @@index([nightId])
  @@map("check_list_items")
}

model BusinessUser {
  id           String   @id @default(cuid())
  adminStatus  Boolean
  email        String
  hotelId      String
  password     String
  username     String

  createdAt    DateTime
  updatedAt    DateTime

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@map("business_users")
}

model GuestUser {
  id                 String    @id @default(cuid())
  username           String
  email              String
  password           String    
  phone              String
  gender             String
  photo              String?
  language           String
  localLanguage      String
  room               String
  hotelId            String
  journeyId          String
  guestCategory      String
  guestCategoryClone String?
  checkoutDate       String
  notificationStatus String
  lastTimeConnected  BigInt
  newConnection      Boolean
  isChatting         Boolean?
  token              GuestToken?

  createdAt          DateTime
  updatedAt          DateTime

  // Visited hotels stored as array of hotel IDs
  hotelVisitedArray String[]
  roomAmeneties     RoomAmeneties[]
  hotel             Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@map("guest_users")
}

model RoomAmeneties {
  id                 String    @id @default(cuid())
  babyBed            Amenety[] @relation("babyBed")
  blanket            Amenety[] @relation("blanket") 
  hairDryer          Amenety[] @relation("hairDryer")
  iron               Amenety[] @relation("iron")
  pillow             Amenety[] @relation("pillow")
  soap               Amenety[] @relation("soap")
  toiletPaper        Amenety[] @relation("toiletPaper")
  towel              Amenety[] @relation("towel")
  guestUserId        String?
  hotelId            String?

  createdAt          DateTime
  updatedAt          DateTime

  hotel Hotel? @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  guestUser GuestUser? @relation(fields: [guestUserId], references: [id], onDelete: Cascade)

  @@map("room_ameneties")
}

model Amenety {
  id                 String    @id @default(cuid())
  checkoutDate       String    
  clientName         String
  room               String
  babyBedId          String?
  blanketId          String?
  hairDryerId        String?
  ironId             String?
  pillowId           String?
  soapId             String?
  toiletPaperId      String?
  towelId            String?

  createdAt          DateTime
  updatedAt          DateTime

  babyBed RoomAmeneties? @relation("babyBed", fields: [babyBedId], references: [id], onDelete: Cascade)
  blanket RoomAmeneties? @relation("blanket", fields: [blanketId], references: [id], onDelete: Cascade)
  hairDryer RoomAmeneties? @relation("hairDryer", fields: [hairDryerId], references: [id], onDelete: Cascade)
  iron RoomAmeneties? @relation("iron", fields: [ironId], references: [id], onDelete: Cascade)
  pillow RoomAmeneties? @relation("pillow", fields: [pillowId], references: [id], onDelete: Cascade)
  soap RoomAmeneties? @relation("soap", fields: [soapId], references: [id], onDelete: Cascade)
  toiletPaper RoomAmeneties? @relation("toiletPaper", fields: [toiletPaperId], references: [id], onDelete: Cascade)
  towel RoomAmeneties? @relation("towel", fields: [towelId], references: [id], onDelete: Cascade)

  @@map("ameneties")
}

model GuestToken {
  id             String    @id @default(cuid())
  guestUserId    String    @unique
  endpoint       String
  expirationTime String?
  auth           String
  p256dh         String
  chats Chat[]

  createdAt      DateTime
  updatedAt      DateTime

  guestUser GuestUser @relation(fields: [guestUserId], references: [id], onDelete: Cascade)

  @@map("guest_tokens")
}

model Feedback {
  id        String   @id @default(cuid())
  hotelId   String

  createdAt DateTime
  updatedAt DateTime

  hotel        Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  satisfaction FeedbackItem[] @relation("SatisfactionItems")
  improvement  FeedbackItem[] @relation("ImprovementItems")

  @@map("feedbacks")
}

model FeedbackItem {
  id                   String   @id @default(cuid())
  author               String
  text                 String
  hotelDept            String
  hotelName            String
  hotelRegion          String
  satisfactionFeedbackId String?
  improvementFeedbackId String?

  createdAt            DateTime
  updatedAt            DateTime

  satisfactionFeedback Feedback? @relation("SatisfactionItems", fields: [satisfactionFeedbackId], references: [id], onDelete: Cascade)
  improvementFeedback  Feedback? @relation("ImprovementItems", fields: [improvementFeedbackId], references: [id], onDelete: Cascade)

  @@map("feedback_items")
}

model Support {
  id           String        @id @default(cuid())
  hotelId      String
  hotelName    String
  pricingModel String
  checkoutDate String
  adminSpeak   Boolean
  status       Boolean

  createdAt    DateTime
  updatedAt    DateTime

  hotel    Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  chatRoom Chat[]

  @@map("support")
}

model Chat {
  id              String   @id @default(cuid()) 
  clientFullName  String
  checkoutDate    String
  guestLanguage   String
  hotelResponding Boolean
  isChatting      Boolean
  room            String
  status          Boolean
  userId          String
  hotelId         String?
  supportId       String?
  guestTokenId    String?

  createdAt DateTime
  updatedAt DateTime
  
  hotel Hotel? @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  support Support? @relation(fields: [supportId], references: [id], onDelete: Cascade)
  token    GuestToken? @relation(fields: [guestTokenId], references: [id], onDelete: Cascade) 
  chatRoom ChatMessage[]

  @@map("chat")
}

model ChatMessage {
  id        String   @id @default(cuid()) 
  author    String
  email     String  
  title     String
  text      String
  photo     String?
  date      DateTime
  room      String
  userId    String
  chatId    String 

  createdAt DateTime
  updatedAt DateTime

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade) 

  @@map("chat_messages")
}